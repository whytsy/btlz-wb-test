{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/btlz-wb-test/src/app.ts",
            "outFiles": [
                "${workspaceFolder}/btlz-wb-test/dist/**/*.js"
            ],
            "envFile": "${workspaceFolder}/btlz-wb-test/.env",
            "runtimeArgs": [
                "--loader", "ts-node/esm",
                "--experimental-specifier-resolution=node"
            ],
            "cwd": "${workspaceFolder}/btlz-wb-test",
            "console": "integratedTerminal"
        }
    ]
}